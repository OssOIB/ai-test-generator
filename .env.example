# ── Anthropic API key ──────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com → API Keys → Create Key
# Then copy this file: cp .env.example .env  and paste your key below.
ANTHROPIC_API_KEY=your_key_here

# ── Optional overrides ─────────────────────────────────────────────────────
# Model to use (defaults to claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# Browser for page crawling (chromium | firefox | webkit)
CRAWLER_BROWSER=chromium

# Max tokens for test generation (increase for complex pages)
MAX_TOKENS=8000
