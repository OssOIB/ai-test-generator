# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (defaults to claude-sonnet-4-6)
# claude-sonnet-4-20250514 is deprecated — claude-sonnet-4-6 is the current alias
AI_MODEL=claude-sonnet-4-6

# Browser for page crawling (chromium | firefox | webkit)
CRAWLER_BROWSER=chromium

# Max tokens for test generation (increase for complex pages)
MAX_TOKENS=8000
